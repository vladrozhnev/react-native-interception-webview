        "react-native": "*",
        "react-native-webview": "*"
    },
    "devDependencies": {
        "@react-native/eslint-config": "0.84.1",
        "@react-native/typescript-config": "0.84.1",
        "@types/jest": "30.0.0",
        "@types/react": "19.2.14",
        "eslint": "8.56.0",
        "jest": "30.3.0",
